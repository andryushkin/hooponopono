{
  "manifest_version": 3,
  "name": "Ho'oponopono Meditation",
  "version": "1.0.4",
  "description": "Join global synchronous Ho'oponopono meditation. Clear your mind, relieve stress, and find inner peace with this Hawaiian mantra.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "wss://hooponopono.online/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
